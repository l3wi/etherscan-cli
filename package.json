{
  "name": "@lewi/etherscan-cli",
  "version": "0.1.0",
  "description": "First-class Etherscan API V2 CLI built with incur.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/l3wi/etherscan-cli.git"
  },
  "homepage": "https://github.com/l3wi/etherscan-cli#readme",
  "bugs": {
    "url": "https://github.com/l3wi/etherscan-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "etherscan": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bunx tsx src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "check": "bun run test && bun run lint && bun run format && bun run build"
  },
  "dependencies": {
    "incur": "^0.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.14"
  }
}
